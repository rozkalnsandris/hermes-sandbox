# Grafana Renderer Authentication Token
# CHANGE_ME: Set this to a secure random token
AUTH_TOKEN=CHANGE_ME

# Grafana Admin Password
# CHANGE_ME: Set this to a secure password
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME

# Grafana Renderer Token (must match AUTH_TOKEN)
GF_RENDERING_RENDERER_TOKEN=CHANGE_ME

# Grafana Server URL (for external access)
# CHANGE_ME: Set to your domain (e.g., https://grafana.example.com)
GF_SERVER_ROOT_URL=http://localhost:3030

# Grafana Server Domain
# CHANGE_ME: Set to your domain (e.g., grafana.example.com)
GF_SERVER_DOMAIN=localhost

# Matter Server Data Path
# CHANGE_ME: Set to your preferred data directory
MATTER_SERVER_DATA_PATH=/tmp/matter-server
